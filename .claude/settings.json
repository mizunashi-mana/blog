{
  "permissions": {
    "allow": [
      "Bash(./scripts/playwright.sh test:*)",
      "Bash(lint-all:*)",
      "Bash(make:*)",
      "Bash(uv run pytest:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Update|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx scripts/cc-hook-format-on-post-tool.ts"
          }
        ]
      }
    ]
  }
}
